{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "server18": "Server=YOUR_SERVER;Database=pfsa;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;",
    "BlobStorage": "DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;"
  },
  "Auth0": {
    "Authority": "https://pfsa.auth0.com/",
    "Audience": "YOUR_API_IDENTIFIER",
    "ClientId": "YOUR_CLIENT_ID"
  },
  "AppSettings": {
    "ApiKeyHeader": "X-API-Key",
    "ValidApiKey": "YOUR_API_KEY",
    "ImageRootPath": "https://littleberry.blob.core.windows.net/bookimages",
    "ImagesContainer": "bookimages"
  },
  "AWS": {
    "BucketName": "pfsa",
    "AccessKey": "YOUR_AWS_ACCESS_KEY",
    "SecretKey": "YOUR_AWS_SECRET_KEY",
    "SES": {
      "Server": "email-smtp.us-west-2.amazonaws.com",
      "Port": 587,
      "User": "YOUR_SES_USER",
      "Password": "YOUR_SES_PASSWORD"
    }
  }
}
